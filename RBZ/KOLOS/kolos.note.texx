\lstdefinelanguage{TSQL}{
  morekeywords={SELECT,FROM,WHERE,INNER,JOIN,LEFT,RIGHT,ON,AS,GROUP,BY,HAVING,
    ORDER,TOP,UNION,ALL,WITH,CTE,CREATE,OR,ALTER,VIEW,PROCEDURE,FUNCTION,LOGIN,
    USER,FOR,GRANT,SCHEMA,USE,EXEC,EXECUTE,DECLARE,SET,IF,ELSE,BEGIN,END,
    DISTRIBUTED,TRANSACTION,COMMIT,ROLLBACK,XACT_ABORT,ENCRYPTION,PASSWORD,
    CHECK_POLICY,INSERT,INTO,VALUES,UPDATE,DELETE,SUM,COUNT,YEAR,NOT,EXISTS,
    OPENROWSET,OPENQUERY,GO,RECONFIGURE,AT},
  sensitive=false,
  morecomment=[l]{--},
  morecomment=[s]{/*}{*/},
  morestring=[b]'
}

\lstset{
  language=TSQL,
  basicstyle=\ttfamily\tiny,
  keywordstyle=\color{kw}\bfseries,
  commentstyle=\color{cm},
  stringstyle=\color{st},
  breaklines=true,
  breakatwhitespace=false,
  columns=fullflexible,
  keepspaces=true,
  showstringspaces=false,
  tabsize=2,
  aboveskip=2pt,
  belowskip=2pt,
  xleftmargin=0pt
}

