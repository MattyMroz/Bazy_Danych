\section{Sprzatanie / DROP / ALTER}
\begin{lstlisting}
DROP VIEW IF EXISTS dbo.Widok1;
DROP PROCEDURE IF EXISTS dbo.PROC4;
EXEC sp_dropserver 'Serwer1','droplogins';   -- usuwa linked + mapping
DROP USER IF EXISTS KONTO1;                  -- najpierw user w bazie
DROP LOGIN KONTO1;                           -- potem login
ALTER LOGIN sa WITH PASSWORD = 'praktyka' OLD_PASSWORD = 'stare';
ALTER LOGIN KONTO1 DISABLE;                  -- wylacz konto
\end{lstlisting}

\section{Patterny zadan kolokwiowych}
\begin{lstlisting}
-- A) Wzrost YoY (rok do roku) - kto najwiekszy wzrost
;WITH r1997 AS (
  SELECT s.ShipperID, SUM(od.UnitPrice*od.Quantity) AS W
  FROM Northwind.dbo.Shippers s
  JOIN Northwind.dbo.Orders o ON s.ShipperID = o.ShipVia
  JOIN Northwind.dbo.[Order Details] od ON o.OrderID = od.OrderID
  WHERE YEAR(o.OrderDate) = 1997 GROUP BY s.ShipperID),
r1998 AS ( ... analogicznie YEAR=1998 ... )
SELECT TOP 1 a.ShipperID, b.W - a.W AS Wzrost
FROM r1997 a JOIN r1998 b ON a.ShipperID = b.ShipperID
ORDER BY Wzrost DESC;

-- B) Kto nie zrealizowal (NOT EXISTS lokalnie + OPENQUERY zdalnie)
SELECT c.CustomerID FROM Northwind.dbo.Customers c
WHERE NOT EXISTS (SELECT 1 FROM Northwind.dbo.Orders o WHERE o.CustomerID = c.CustomerID);

SELECT * FROM OPENQUERY(Serwer1,'
  SELECT c.CustomerID FROM Northwind.dbo.Customers c
  LEFT JOIN Northwind.dbo.Orders o ON c.CustomerID = o.CustomerID
  GROUP BY c.CustomerID HAVING COUNT(o.OrderID)=0');

-- C) TOP N po agregacji (najwiekszy klient/produkt)
SELECT TOP 3 p.ProductName, SUM(od.UnitPrice*od.Quantity) AS W
FROM Northwind.dbo.Products p
JOIN Northwind.dbo.[Order Details] od ON p.ProductID = od.ProductID
GROUP BY p.ProductName ORDER BY W DESC;

-- D) Suma sprzedazy w roku (procedura przez linked server)
CREATE OR ALTER PROCEDURE dbo.SprzedazRok @Rok INT AS
SELECT YEAR(o.OrderDate) AS Rok,
       SUM(od.UnitPrice * od.Quantity * (1 - od.Discount)) AS Wartosc
FROM Serwer1.Northwind.dbo.Orders o
JOIN Serwer1.Northwind.dbo.[Order Details] od ON o.OrderID = od.OrderID
WHERE YEAR(o.OrderDate) = @Rok GROUP BY YEAR(o.OrderDate);
GO
GRANT EXECUTE ON dbo.SprzedazRok TO KONTO1;

-- E) Zapytanie rozproszone 4 zrodla (Customers lokal + Orders/OD/Products zdalne)
SELECT c.CompanyName, o.OrderID, p.ProductName, od.UnitPrice*od.Quantity AS W
FROM Northwind.dbo.Customers c
JOIN Serwer1.Northwind.dbo.Orders o ON c.CustomerID = o.CustomerID
JOIN Serwer1.Northwind.dbo.[Order Details] od ON o.OrderID = od.OrderID
JOIN Serwer1.Northwind.dbo.Products p ON od.ProductID = p.ProductID;
\end{lstlisting}

\section{INSERT/DELETE przez linked + OPENQUERY (lokalny SQL i Oracle)}
\begin{lstlisting}
-- 4-czlonowo
INSERT INTO Serwer1.Northwind.dbo.Products (ProductName, UnitPrice) VALUES ('TestX', 1);
DELETE FROM Serwer1.Northwind.dbo.Products WHERE ProductName='TestX';

-- OPENQUERY (T-SQL wykonywany po zdalnej stronie)
INSERT INTO OPENQUERY(Serwer1,'SELECT ProductName, UnitPrice FROM Northwind.dbo.Products')
VALUES ('TestY', 2);

-- Oracle przez OPENQUERY
INSERT INTO OPENQUERY(OraPD25,'SELECT EMPLOYEEID, LASTNAME, FIRSTNAME FROM EMPLOYEES')
VALUES (999, 'Test', 'X');
DELETE FROM OPENQUERY(OraPD25,'SELECT EMPLOYEEID FROM EMPLOYEES WHERE EMPLOYEEID=999');
\end{lstlisting}

\section{Tabela docelowa (SQL i Oracle)}
\begin{lstlisting}
-- SQL Server
CREATE TABLE dbo.koledzy (
  indeks   INT NOT NULL PRIMARY KEY,
  nazwisko VARCHAR(50) NOT NULL,
  imie     VARCHAR(25) NOT NULL);
GRANT SELECT, INSERT, UPDATE, DELETE ON dbo.koledzy TO PUBLIC;

-- Oracle (po stronie NORTHWIND/PD251190 w SQL Developer)
-- CREATE TABLE KOLEDZY (
--   INDEKS NUMBER(15) NOT NULL PRIMARY KEY,
--   NAZWISKO VARCHAR2(50) NOT NULL,
--   IMIE VARCHAR2(25) NOT NULL);
-- GRANT SELECT, INSERT, UPDATE, DELETE ON KOLEDZY TO PUBLIC;
\end{lstlisting}

\section{Procedura SQL z parametrami (insert lokalny)}
\begin{lstlisting}
CREATE OR ALTER PROCEDURE dbo.dodaj_kolege_sql
  @indeks   INT,
  @nazwisko VARCHAR(50),
  @imie     VARCHAR(25)
AS
BEGIN
  SET NOCOUNT ON;
  INSERT INTO dbo.koledzy (indeks, nazwisko, imie)
  VALUES (@indeks, @nazwisko, @imie);
END;
GO
EXEC dbo.dodaj_kolege_sql @indeks=62001, @nazwisko='Nowak', @imie='Anna';
\end{lstlisting}

